# คัดลอกเป็นไฟล์ .env แล้วแก้ตามเครื่อง
# cp .env.example .env

# ตรงกับ docker-compose.yml ที่ root (user=postgres password=postgres db=iropa)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iropa?schema=public"

JWT_SECRET="เปลี่ยนเป็นสตริงยาวๆ-อย่าใช้ค่าเดิมใน production"
# ต้องตรงกับพอร์ตที่ Frontend ใช้ใน NEXT_PUBLIC_API_URL
PORT=4001

# คั่นด้วย comma ถ้ามีหลาย origin
CORS_ORIGIN=http://localhost:3000
