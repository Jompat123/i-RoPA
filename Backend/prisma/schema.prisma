generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  users       User[]
  ropaEntries RopaEntry[]
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(DEPARTMENT_USER)
  departmentId String?
  createdAt    DateTime  @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
  createdRopas RopaEntry[]
  auditLogs    AuditLog[]
}

enum Role {
  ADMIN
  DEPARTMENT_USER
  VIEWER
  AUDITOR
}

model RopaEntry {
  id               String         @id @default(uuid())
  referenceCode    String?        @unique
  processName      String
  role             RopaRole       @default(controller)
  purpose          String?
  personalDataTypes String[]
  dataCategory     String?
  dataType         DataType       @default(GENERAL)
  dataControllerAddress String?
  collectionMethod String?
  collectionMethodType CollectionMethodType?
  dataSource       String?
  collectionSource CollectionSource?
  legalBasis       String?
  minorConsentUnder10 Boolean?
  minorConsent10to20 Boolean?
  minorConsentOtherNote String?
  crossBorderTransfer Boolean     @default(false)
  transferCountry  String?
  transferToAffiliate Boolean?
  transferAffiliateName String?
  transferMethod   String?
  protectionStandard String?
  legalExemption28 String?
  retentionPeriod  String?
  storageDataType  StorageDataType?
  storageMethod    String?
  rightsAccessNote String?
  deletionMethod   String?
  disclosureNote   String?
  rightsRefusalNote String?
  securityMeasuresSummary String?
  securityOrg      String?
  securityTech     String?
  securityPhysical String?
  securityAccessControl String?
  securityUserResponsibility String?
  securityAudit String?
  riskLevel        RiskLevel      @default(LOW)
  status           EntryStatus    @default(DRAFT)
  reviewDecision   ReviewDecision?
  reviewNote       String?
  reviewChecks     Json?
  destructionConfirmedAt DateTime?
  destructionProofUrl String?
  destructionNote String?
  departmentId     String
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  department       Department     @relation(fields: [departmentId], references: [id])
  createdBy        User           @relation(fields: [createdById], references: [id])
}

enum DataType {
  GENERAL
  SENSITIVE
}

enum RiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum EntryStatus {
  DRAFT
  PENDING
  NEEDS_FIX
  APPROVED
  COMPLETE
}

enum RopaRole {
  controller
  processor
}

enum CollectionMethodType {
  soft
  hard
}

enum CollectionSource {
  direct
  other
}

enum StorageDataType {
  soft
  hard
}

enum ReviewDecision {
  approve
  reject
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  tableName String
  recordId  String
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
