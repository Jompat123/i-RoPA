{
  "name": "i-ropa",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix Frontend",
    "dev:stop": "bash scripts/kill-dev-ports.sh",
    "dev:fresh": "npm run dev:stop && npm run dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:setup": "npm run db:up && npm --prefix Backend run db:reset",
    "build": "npm run build --prefix Frontend",
    "lint": "npm run lint --prefix Frontend",
    "start": "npm run start --prefix Frontend",
    "test:frontend": "npm run test:run --prefix Frontend",
    "test:backend": "npm run test:run --prefix Backend"
  }
}
